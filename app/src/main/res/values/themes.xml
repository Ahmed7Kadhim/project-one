<resources>
    <style name="Theme.ProjectOne" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background_dark</item>
    </style>

    <style name="CalculatorButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@color/button_dark</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="CalculatorButtonAccent" parent="CalculatorButton">
        <item name="android:background">@color/button_accent</item>
    </style>
</resources>
